{
  "name": "ecommerce",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@reduxjs/toolkit": "^2.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react-router-dom": "^5.3.3",
    "ajv": "^8.20.0",
    "antd": "^6.3.7",
    "i18next": "^24.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^15.7.4",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.0",
    "react-scripts": "5.0.1",
    "redux-observable": "^3.0.0-rc.3",
    "redux-persist": "^6.0.0",
    "rxjs": "^7.8.2",
    "typescript": "^5.9.3",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "\\.(css|less|scss)$": "<rootDir>/src/__mocks__/styleMock.ts",
      "\\.(jpg|jpeg|png|gif|svg|webp)$": "<rootDir>/src/__mocks__/fileMock.ts",
      "^react-router-dom$": "<rootDir>/node_modules/react-router-dom/dist/index.js",
      "^react-router$": "<rootDir>/node_modules/react-router/dist/development/index.js",
      "^react-router/dom$": "<rootDir>/node_modules/react-router/dist/development/dom-export.js",
      "^react-router/internal$": "<rootDir>/node_modules/react-router/dist/development/index.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@ant-design|antd|rc-.*|@rc-component|react-router|react-router-dom)/)"
    ]
  }
}
